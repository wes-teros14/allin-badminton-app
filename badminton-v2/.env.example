# Shared defaults (no secrets) — goes in .env
VITE_APP_URL=http://localhost:5173

# Supabase credentials — put in .env.development (dev) and .env.production (prod)
# Vite auto-loads the right file: `npm run dev` → .env.development, `npm run build` → .env.production
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Required only for running the seed script (npm run seed)
# Get from: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
